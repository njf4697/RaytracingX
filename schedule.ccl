# Schedule definition for thorn RaytracingX
# ===================================================

if (do_raytracing) {

SCHEDULE R_ParticlesContainer_setup AT CCTK_POSTINITIAL {
    LANG: C
    OPTIONS: global
} "setup"

if ((particle_plot_every>0)||(particle_tsv_every>0) ){
    SCHEDULE R_ParticlesContainer_print AT CCTK_POSTINITIAL AFTER setup
    {
        LANG: C
        OPTIONS: global
    } "print the particles"
}

SCHEDULE R_ParticlesContainer_evolve AT evol
{
    LANG: C
    OPTIONS: global
} "Photons evolution"

if ((particle_plot_every||particle_tsv_every) ) {
    SCHEDULE R_ParticlesContainer_print AT evol AFTER R_ParticlesContainer_evolve
    {
        LANG: C
        OPTIONS: global
    } "print the particles"
}

SCHEDULE particles_remaining AT evol
{
    LANG: C
    OPTIONS: global
} "Number of particles remaining"

SCHEDULE R_ParticlesContainer_final_cleanup at CCTK_SHUTDOWN{
    LANG: C
    OPTIONS: global
} "cleaning everything"

}
